{
  "name": "craftx-books",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vitepress dev docs",
    "import:book": "node scripts/import-book.mjs",
    "generate:sidebar": "node scripts/generate-sidebar.mjs",
    "generate:stats": "node scripts/generate-content-stats.mjs",
    "prebuild": "node scripts/generate-sidebar.mjs && node scripts/generate-content-stats.mjs && node scripts/escape-vitepress-braces.mjs && node scripts/normalize-missing-assets.mjs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs",
    "check:deadlinks": "node scripts/check-deadlinks.mjs",
    "lint": "markdownlint-cli2",
    "lint:fix": "markdownlint-cli2 --fix",
    "test": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "markdownlint-cli2": "^0.17.0",
    "medium-zoom": "^1.1.0",
    "vitepress": "^1.6.4"
  }
}
